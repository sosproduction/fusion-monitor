    {
      "id": 65, "title": "Fusion Rate (×10²⁰ /s)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 37, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "displayName": "Fusion Rate /s",
          "thresholds": { "mode": "absolute", "steps": [
