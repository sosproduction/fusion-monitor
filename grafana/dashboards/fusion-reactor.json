        "defaults": {
          "unit": "none", "displayName": "MTBD (hr)",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 48 }, { "color": "green", "value": 100 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "fusion_perf_MTBD_hours", "datasource": "Prometheus" }]
