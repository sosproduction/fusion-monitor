        "defaults": {
          "unit": "none", "displayName": "Warnings 24h",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "fusion_alarms_warnings_24h", "datasource": "Prometheus" }]
